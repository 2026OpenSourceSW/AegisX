<task_report_context>
  <instruction>Generate a comprehensive evaluation report for the user's task</instruction>

  <user_task>
    <input>{{.Task.Input}}</input>
  </user_task>

  {{if .Tasks}}
  <previous_tasks>
    {{range .Tasks}}
    <task>
      <id>{{.ID}}</id>
      <input>{{.Input}}</input>
      <status>{{.Status}}</status>
      <result>{{.Result}}</result>
    </task>
    {{end}}
  </previous_tasks>
  {{end}}

  {{if .CompletedSubtasks}}
  <completed_subtasks>
    {{range .CompletedSubtasks}}
    <subtask>
      <id>{{.ID}}</id>
      <title>{{.Title}}</title>
      <description>{{.Description}}</description>
      <status>{{.Status}}</status>
      <result>{{.Result}}</result>
    </subtask>
    {{end}}
  </completed_subtasks>
  {{end}}

  {{if .PlannedSubtasks}}
  <planned_subtasks>
    {{range .PlannedSubtasks}}
    <subtask>
      <id>{{.ID}}</id>
      <title>{{.Title}}</title>
      <description>{{.Description}}</description>
    </subtask>
    {{end}}
  </planned_subtasks>
  {{else}}
  <planned_subtasks status="empty">
    <message>All subtasks have been completed. Review their statuses and results to prepare your report.</message>
  </planned_subtasks>
  {{end}}

  {{if .ExecutionState}}
  <execution_state>
  {{.ExecutionState}}
  </execution_state>
  {{end}}

  {{if .ExecutionLogs}}
  <execution_logs>
  {{.ExecutionLogs}}
  </execution_logs>
  {{end}}
  {{if .QuickScanEnabled}}
  <quick_scan_profile>
    <marker>{{.QuickScanMarker}}</marker>
    <time_budget>{{.QuickScanBudgetMinutes}}</time_budget>
    <max_subtasks>{{.QuickScanMaxSubtasks}}</max_subtasks>
    <max_general_agent_tool_calls>{{.QuickScanMaxGeneralAgentToolCalls}}</max_general_agent_tool_calls>
    <max_limited_agent_tool_calls>{{.QuickScanMaxLimitedAgentToolCalls}}</max_limited_agent_tool_calls>
    <post_exploitation_disabled>{{.QuickScanDisablePostExploit}}</post_exploitation_disabled>
    <rules>
      {{range .QuickScanRules}}<rule>{{.}}</rule>
      {{end}}
    </rules>
    <report_instruction>Include 쉬운 요약, 발견 항목 요약, 위험도별 발견 항목, detailed 주요 발견 사항, evidence, OWASP Top 10:2025 mapping, and 추가 정밀 점검 필요 for quick-scope uncertainty. Put summary tables before detailed findings: 위험도 | OWASP Top 10:2025 유형 | 취약점 and 위험도 | 개수 | 항목. Keep a clean Markdown heading hierarchy. Do not start headings with status emojis, checkmarks, or raw task or subtask IDs; use risk-level emojis only inside tables or body text when helpful.</report_instruction>
  </quick_scan_profile>
  {{end}}
</task_report_context>
